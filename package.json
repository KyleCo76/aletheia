{
  "name": "aletheia",
  "version": "0.2.6",
  "type": "module",
  "bin": { "aletheia": "./dist/cli/cli.js" },
  "exports": {
    ".": "./dist/server/index.js"
  },
  "files": ["dist", "hooks", "src/templates"],
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "smol-toml": "^1.6.1",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^18.19.0"
  },
  "scripts": {
    "build": "tsc && npm run copy-hooks",
    "copy-hooks": "mkdir -p hooks/unix hooks/windows && cp src/hooks/unix/*.sh hooks/unix/ && cp src/hooks/windows/*.js hooks/windows/ && chmod +x hooks/unix/*.sh hooks/windows/*.js",
    "prepare": "node ./scripts/prepare.mjs",
    "test": "npm run build && node --test --test-reporter spec 'test/**/*.test.mjs'"
  }
}
